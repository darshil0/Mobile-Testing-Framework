<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="Mobile Test Suite - iOS" parallel="false" verbose="1">
    <listeners>
        <listener class-name="com.mobile.testing.listeners.TestListener"/>
        <listener class-name="com.mobile.testing.listeners.AnnotationTransformer"/>
    </listeners>

    <test name="iOS Tests">
        <parameter name="platform" value="ios"/>
        <classes>
            <class name="com.mobile.testing.tests.IOSTest"/>
        </classes>
    </test>
</suite>
